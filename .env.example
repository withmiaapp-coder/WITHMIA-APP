# ============================================================================
# WITHMIA - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# Documentation: https://github.com/withmiaapp-coder/withmia/wiki/Configuration
# ============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Withmia
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Santiago
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# ─── Super Admin ─────────────────────────────────────────────────────────────
# Comma-separated emails with super-admin access
SUPER_ADMIN_EMAILS=admin@example.com
ADMIN_SECRET_KEY=
DEBUG_KEY=

# ─── Database (Primary - PostgreSQL) ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=withmia
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ─── Session & Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ─── Broadcasting (Laravel Reverb) ──────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=admin@example.com

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Google OAuth & Services ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=${APP_URL}/api/calendar/google/callback
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ENGINE_ID=

# ─── Microsoft OAuth ────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALENDAR_REDIRECT_URI=${APP_URL}/api/calendar/microsoft/callback

# ─── Calendly OAuth ─────────────────────────────────────────────────────────
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=${APP_URL}/api/calendar/calendly/callback

# ─── Chatwoot ────────────────────────────────────────────────────────────────
CHATWOOT_URL=http://localhost:3000
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_SUPER_ADMIN_TOKEN=
CHATWOOT_API_KEY=
CHATWOOT_PLATFORM_API_TOKEN=
CHATWOOT_WEBSITE_TOKEN=
CHATWOOT_WEBHOOK_SECRET=

# Chatwoot Database (direct provisioning)
CHATWOOT_DATABASE_URL=
CHATWOOT_DB_HOST=127.0.0.1
CHATWOOT_DB_PORT=5432
CHATWOOT_DB_DATABASE=chatwoot
CHATWOOT_DB_USERNAME=postgres
CHATWOOT_DB_PASSWORD=

# ─── Evolution API (WhatsApp) ───────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_URL=
EVOLUTION_WEBHOOK_SECRET=
EVOLUTION_INSTANCE_NAMING=company_id
EVOLUTION_DATABASE_URL=

# Evolution Database
EVOLUTION_DB_HOST=127.0.0.1
EVOLUTION_DB_PORT=5432
EVOLUTION_DB_DATABASE=evolution
EVOLUTION_DB_USERNAME=postgres
EVOLUTION_DB_PASSWORD=

# ─── n8n (Workflow Automation) ──────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_INTERNAL_URL=http://localhost:5678
N8N_PUBLIC_URL=http://localhost:5678
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

# ─── Qdrant (Vector Database) ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Flow.cl (Payments - Chile) ─────────────────────────────────────────────
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_API_URL=https://www.flow.cl/api
FLOW_SANDBOX=true
FLOW_PLAN_MONTHLY_ID=
FLOW_PLAN_ANNUAL_ID=
FLOW_ADDON_MEMBER_MONTHLY_ID=
FLOW_ADDON_MEMBER_ANNUAL_ID=

# ─── Billing ────────────────────────────────────────────────────────────────
BILLING_BASE_PRICE_MONTHLY=19990
BILLING_BASE_PRICE_ANNUAL=189990
BILLING_PER_MEMBER_MONTHLY=9990
BILLING_PER_MEMBER_ANNUAL=95990
BILLING_TRIAL_DAYS=0

# ─── Facebook / Meta ────────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v20.0
FACEBOOK_WHATSAPP_CONFIG_ID=

# ─── WooCommerce ─────────────────────────────────────────────────────────────
WOOCOMMERCE_WEBHOOK_SECRET=

# ─── dLocal (Payments) ──────────────────────────────────────────────────────
DLOCAL_API_KEY=
DLOCAL_SECRET_KEY=
DLOCAL_API_URL=https://api.dlocalgo.com

# ─── Sentry (Error Tracking) ────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Horizon (Queue Dashboard) ──────────────────────────────────────────────
HORIZON_ADMIN_EMAILS=admin@example.com
HORIZON_PREFIX=withmia_horizon:

# ─── HTTP Timeouts ──────────────────────────────────────────────────────────
HTTP_TIMEOUT_DEFAULT=10
HTTP_TIMEOUT_CHATWOOT=15
HTTP_TIMEOUT_N8N=120
HTTP_TIMEOUT_OPENAI=180
HTTP_TIMEOUT_TRAINING=30

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
