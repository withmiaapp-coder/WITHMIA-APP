# Railway Environment Variables Template
# Copy these to Railway Variables tab

APP_NAME="WithMIA"
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_APP_KEY_HERE

# Railway MySQL (Auto-injected by Railway)
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=

# Map Railway MySQL vars to Laravel
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# Railway Redis (Auto-injected by Railway when you add Redis service)
# REDISHOST=
# REDISPORT=
# REDISUSER=
# REDISPASSWORD=

# Map Railway Redis vars to Laravel
REDIS_HOST=${REDISHOST}
REDIS_PORT=${REDISPORT}
REDIS_USERNAME=${REDISUSER}
REDIS_PASSWORD=${REDISPASSWORD}
REDIS_CLIENT=phpredis

# Cache & Session with Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Filesystem
FILESYSTEM_DISK=public

# URLs
APP_URL=https://app.withmia.com

# Mail (Resend)
MAIL_MAILER=resend
RESEND_API_KEY=your_resend_key_here

# Chatwoot Integration
CHATWOOT_API_URL=https://your-chatwoot-instance.com
CHATWOOT_API_TOKEN=your_chatwoot_token

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your_evolution_key
