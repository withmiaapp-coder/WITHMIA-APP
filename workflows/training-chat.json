                      "parameters":  {
                                         "jsCode":  "// Prepare Qdrant search request\nconst prevData = $(\u0027Prepare Training Data\u0027).first().json;\nconst embedding = $input.first().json.data[0].embedding;\n\nreturn {\n  json: {\n    ...prevData,\n    query_vector: embedding\n  }\n};"
