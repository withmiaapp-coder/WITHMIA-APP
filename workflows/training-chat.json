                  {
                      "parameters":  {
                                         "jsCode":  "const openaiResponse = $input.first().json; const aiResponse = openaiResponse.choices[0].message.content || \u0027\u0027; const prevNode = $(\u0027Build Context \u0026 Messages\u0027); const prevData = prevNode.first().json; const userMessage = prevData.user_message || \u0027\u0027; const openaiApiKey = prevData.openai_api_key || \u0027\u0027; const collectionName = prevData.collection_name || \u0027\u0027; const companySlug = prevData.company_slug || \u0027\u0027; const qdrantHost = prevData.qdrant_host || \u0027\u0027; const deduplication = prevData.deduplication || null; const saveKeywords = [\u0027ejemplo\u0027, \u0027asi deberias\u0027, \u0027responde asi\u0027, \u0027cuando pregunten\u0027, \u0027si alguien pregunta\u0027, \u0027recuerda que\u0027, \u0027importante\u0027, \u0027nuestro horario\u0027, \u0027nuestros precios\u0027, \u0027vendemos\u0027, \u0027ofrecemos\u0027, \u0027nuestro telefono\u0027, \u0027nuestra direccion\u0027, \u0027nuestro email\u0027, \u0027nuestra pagina\u0027, \u0027nuestro whatsapp\u0027]; const shouldSave = saveKeywords.some(kw =\u003e userMessage.toLowerCase().includes(kw)); const textToSave = \u0027EJEMPLO DE ENTRENAMIENTO\\\\n\\\\nUsuario: \u0027 + userMessage + \u0027\\\\n\\\\nRespuesta del asistente: \u0027 + aiResponse; return { json: { company_slug: companySlug, collection_name: collectionName, openai_api_key: openaiApiKey, qdrant_host: qdrantHost, deduplication: deduplication, user_message: userMessage, ai_response: aiResponse, should_save: shouldSave, text_to_save: textToSave } };"
