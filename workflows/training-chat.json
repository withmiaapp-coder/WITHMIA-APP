                                       1320,
                                       300
                                   ],
                      "id":  "call-openai",
                      "name":  "Call OpenAI Chat"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const openaiResponse = $input.first().json;\nconst aiResponse = openaiResponse.choices[0].message.content || '';\nconst prevNode = $('Build Context \\u0026 Messages');\nconst prevData = prevNode.first().json;\nconst userMessage = prevData.user_message || '';\nconst openaiApiKey = prevData.openai_api_key || '';\nconst collectionName = prevData.collection_name || '';\nconst companySlug = prevData.company_slug || '';\nconst qdrantHost = prevData.qdrant_host || '';\nconst deduplication = prevData.deduplication || null;\n\n// 🔍 PRIMERO: Verificar si PHP ya detectó que es una pregunta (action === 'skip')\nconst isSkipped = deduplication && deduplication.action === 'skip';\n\n// 🔍 SEGUNDO: Verificar si parece pregunta por patrones\nconst lowerMessage = userMessage.toLowerCase();\nconst questionIndicators = [\n  '¿', '?',\n  'qué ', 'que ', 'cuál ', 'cual ', 'cómo ', 'como ',\n  'cuándo ', 'cuando ', 'dónde ', 'donde ', 'quién ', 'quien ',\n  'tienen ', 'tienes ', 'hay ', 'existe ', 'puedo ', 'pueden '\n];\nconst isQuestion = questionIndicators.some(q => lowerMessage.includes(q) || userMessage.includes(q));\n\n// 🔍 TERCERO: Verificar si tiene keywords de entrenamiento\nconst saveKeywords = [\n  'ejemplo', 'asi deberias', 'responde asi', 'cuando pregunten',\n  'si alguien pregunta', 'recuerda que', 'importante',\n  'nuestro horario', 'nuestros precios', 'vendemos', 'ofrecemos',\n  'nuestro telefono', 'nuestra direccion', 'nuestro email',\n  'nuestra pagina', 'nuestro whatsapp', 'abrimos', 'cerramos',\n  'trabajamos de', 'atendemos de', 'el precio es', 'cuesta',\n  'estamos ubicados', 'nuestra direccion es'\n];\nconst hasTrainingKeywords = saveKeywords.some(kw => lowerMessage.includes(kw));\n\n// 📝 DECISIÓN: Guardar solo si:\n// - NO fue marcado como 'skip' por PHP\n// - NO parece pregunta O tiene keywords de entrenamiento explícitos\nconst shouldSave = !isSkipped && (!isQuestion || hasTrainingKeywords);\n\nconst textToSave = userMessage; // Solo el mensaje, sin formato extra\n\nreturn {\n  json: {\n    company_slug: companySlug,\n    collection_name: collectionName,\n    openai_api_key: openaiApiKey,\n    qdrant_host: qdrantHost,\n    qdrant_api_key: prevData.qdrant_api_key || '',\n    deduplication: deduplication,\n    user_message: userMessage,\n    ai_response: aiResponse,\n    should_save: shouldSave,\n    is_question: isQuestion,\n    is_skipped: isSkipped,\n    text_to_save: textToSave\n  }\n};"
                                     },
