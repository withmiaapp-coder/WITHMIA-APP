                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const data = $input.first().json;\nreturn {\n  json: {\n    response: data.ai_response,\n    saved: !data.skipped,\n    message: data.skipped ? 'Respuesta sin guardar' : 'Guardado en la base de conocimiento'\n  }\n};"
                                     },
