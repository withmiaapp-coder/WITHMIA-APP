                  {
                      "parameters":  {
                                         "jsCode":  "// Build context from Qdrant results and prepare OpenAI request\nconst prevData = $(\u0027Prepare Search\u0027).first().json;\nconst searchResults = $input.first().json.result || [];\n\nlet contextText = \u0027\u0027;\nif (searchResults \u0026\u0026 searchResults.length \u003e 0) {\n  contextText = searchResults\n    .filter(r =\u003e r.score \u003e 0.5)\n    .map(r =\u003e r.payload?.text || \u0027\u0027)\n    .filter(t =\u003e t)\n    .join(\u0027\\n\\n---\\n\\n\u0027);\n}\n\nif (!contextText) {\n  contextText = \u0027Sin contexto previo en la base de conocimiento.\u0027;\n}\n\nconst messages = [\n  {\n    role: \u0027system\u0027,\n    content: prevData.system_prompt + \u0027\\n\\nCONTEXTO DE LA EMPRESA (informaci?n ya aprendida):\\n\u0027 + contextText\n  }\n];\n\nif (prevData.conversation_history \u0026\u0026 prevData.conversation_history.length \u003e 0) {\n  for (const msg of prevData.conversation_history.slice(-10)) {\n    messages.push({\n      role: msg.role || \u0027user\u0027,\n      content: msg.content || msg.message || \u0027\u0027\n    });\n  }\n}\n\nmessages.push({\n  role: \u0027user\u0027,\n  content: prevData.user_message\n});\n\nreturn {\n  json: {\n    ...prevData,\n    context_text: contextText,\n    messages: messages\n  }\n};"
                                     },
