                    }
                ]
            ]
        },
        "Is Incoming Message?": {
            "main": [
                [
                    {
                        "node": "Normalize Chatwoot Data",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Normalize Chatwoot Data": {
            "main": [
                [
                    {
                        "node": "Has Content?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Has Content?": {
            "main": [
                [
                    {
                        "node": "Get Company Config",
                        "type": "main",
