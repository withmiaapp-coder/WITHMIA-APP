                ]
            ]
        },
        "Get Company Config": {
            "main": [
                [
                    {
                        "node": "Validate Company Config",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Validate Company Config": {
            "main": [
                [
                    {
                        "node": "AI Agent",
