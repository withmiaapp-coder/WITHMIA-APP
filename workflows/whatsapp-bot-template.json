                        "index": 0
                    }
                ]
            ]
        },
        "Normalize Data": {
            "main": [
                [
                    {
                        "node": "Is From User?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Is From User?": {
            "main": [
                [
                    {
                        "node": "Prepare Context",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Prepare Context": {
            "main": [
                [
                    {
                        "node": "Embed User Query",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Embed User Query": {
            "main": [
                [
                    {
                        "node": "Search Qdrant Context",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Search Qdrant Context": {
            "main": [
                [
                    {
                        "node": "Build Messages",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Build Messages": {
            "main": [
                [
                    {
                        "node": "Call OpenAI Chat",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Call OpenAI Chat": {
            "main": [
                [
                    {
                        "node": "Process Response",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Process Response": {
            "main": [
                [
                    {
                        "node": "Send WhatsApp Response",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "active": false,
    "settings": {
        "executionOrder": "v1",
        "timezone": "America/Santiago",
        "callerPolicy": "workflowsFromSameOwner"
    },
    "meta": {
        "templateCredsSetupCompleted": true
    },
    "tags": []
}
