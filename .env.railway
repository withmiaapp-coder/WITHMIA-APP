# === RAILWAY ENVIRONMENT VARIABLES ===
# Copy these to your Railway project's environment variables

# Laravel Configuration
APP_NAME=WithMIA
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mia-app-production-1462.up.railway.app
APP_KEY=base64:4KvJ8x9zQpT2wN5mH7yR6kL3sF1dG9bV8cX0jP4nM2A=  # ⚠️ IMPORTANTE: Genera una nueva con "php generate-key.php"

# Database (Railway MySQL Plugin)
# Railway auto-injects these when you add MySQL service
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# Redis (Railway Redis Plugin)
# Railway auto-injects these when you add Redis service
REDIS_HOST=${REDISHOST}
REDIS_PASSWORD=${REDISPASSWORD}
REDIS_PORT=${REDISPORT}

# Session & Cache
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
# SESSION_DOMAIN dejarlo vacío para que Laravel use el dominio actual automáticamente
# Si usas app.withmia.com, NO pongas SESSION_DOMAIN o ponlo vacío
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Broadcasting
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=withmia-app
REVERB_APP_KEY=your-reverb-key
REVERB_APP_SECRET=your-reverb-secret
REVERB_HOST=your-app.railway.app
REVERB_PORT=443
REVERB_SCHEME=https

# File Storage (Local for now)
FILESYSTEM_DISK=public

# Mail (Resend - Free 100 emails/day)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=re_your_api_key_here

# Chatwoot Configuration
CHATWOOT_API_BASE_URL=http://chatwoot.railway.internal:3000
CHATWOOT_PLATFORM_API_TOKEN=RdT1HCSky2qTrSTvfU9zxCey
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_TOKEN=RdT1HCSky2qTrSTvfU9zxCey
CHATWOOT_API_KEY=RdT1HCSky2qTrSTvfU9zxCey
CHATWOOT_URL=http://n8n-admin.withmia.com

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=withmia_evolution_api_key_2025_secure_token

# AWS (Remove if not using)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# OpenAI
OPENAI_API_KEY=your_openai_key

# n8n Workflow Automation
N8N_URL=https://n8n-production-dace.up.railway.app
N8N_INTERNAL_URL=http://n8n.railway.internal:5678
N8N_PUBLIC_URL=https://n8n-production-dace.up.railway.app
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_SECRET=withmia_n8n_secret_2024

# Qdrant Vector Database
QDRANT_URL=https://qdrant-production-c156.up.railway.app
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge

# Vite
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${REVERB_APP_KEY}"
VITE_PUSHER_HOST="${REVERB_HOST}"
VITE_PUSHER_PORT="${REVERB_PORT}"
VITE_PUSHER_SCHEME="${REVERB_SCHEME}"
