{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.reverb",
    "watchPatterns": [
      "Dockerfile.reverb",
      "start-reverb.sh",
      "app/Broadcasting/**",
      "config/broadcasting.php",
      "config/reverb.php",
      "composer.json",
      "composer.lock"
    ]
  },
  "deploy": {
    "startCommand": "/app/start-reverb.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  }
}
