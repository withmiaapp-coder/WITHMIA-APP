{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "app/Broadcasting/**",
      "config/broadcasting.php",
      "config/reverb.php",
      "composer.json",
      "composer.lock"
    ]
  },
  "deploy": {
    "startCommand": "bash start-reverb.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
