{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "app/Broadcasting/**",
      "config/broadcasting.php",
      "config/reverb.php",
      "composer.json",
      "composer.lock"
    ]
  },
  "deploy": {
    "startCommand": "php artisan reverb:start --host=0.0.0.0 --port=$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
