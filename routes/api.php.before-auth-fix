    Route::post('/user/inbox/create', [ChatwootController::class, 'createInbox'])
        ->name('chatwoot.user.inbox.create');
    
    // Asignar agente a inbox
    Route::post('/user/inbox/assign-agent', [ChatwootController::class, 'assignAgentToInbox'])
        ->name('chatwoot.user.inbox.assign');
    
    // ========== RUTAS DE ADMINISTRADOR (SOLO SUPER ADMIN) ==========
    // TODO: Agregar middleware de admin cuando esté implementado
    
    Route::prefix('admin')->group(function () {
        // Gestión de agentes
        Route::get('/agents', [ChatwootController::class, 'getAgents'])
            ->name('chatwoot.admin.agents');
        Route::post('/agents', [ChatwootController::class, 'createAgent'])
            ->name('chatwoot.admin.agents.create');
        Route::delete('/agents/{agentId}', [ChatwootController::class, 'deleteAgent'])
            ->name('chatwoot.admin.agents.delete');
        
        // Gestión de equipos
        Route::get('/teams', [ChatwootController::class, 'getTeams'])
            ->name('chatwoot.admin.teams');
        Route::post('/teams', [ChatwootController::class, 'createTeam'])
            ->name('chatwoot.admin.teams.create');
    });
});

