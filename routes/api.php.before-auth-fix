/*
|--------------------------------------------------------------------------
| Evolution API Routes
|--------------------------------------------------------------------------
|
| Rutas para gestionar instancias de WhatsApp con Evolution API
| Soporta arquitectura multi-tenant para múltiples empresas
|
*/

Route::prefix('evolution-whatsapp')->group(function () {
    
    // Webhook público (sin autenticación - Evolution API lo llama)
    Route::post('/webhook', [EvolutionApiController::class, 'webhook'])
        ->name('evolution.webhook');

    // Estado público (solo lectura)
    Route::get('/status/{instanceName?}', [EvolutionApiController::class, 'getStatus'])
        ->name('evolution.status');

    // Conexión pública (el instanceName único identifica al usuario)
    Route::post('/connect/{instanceName?}', [EvolutionApiController::class, 'connect'])
        ->name('evolution.connect');

    // Desconexión pública (logout de WhatsApp)
    Route::post('/disconnect/{instanceName?}', [EvolutionApiController::class, 'disconnect'])
        ->name('evolution.disconnect');
    
    // Eliminación de instancia pública
    Route::delete('/instance/{instanceName?}', [EvolutionApiController::class, 'deleteInstance'])
        ->name('evolution.delete');

    // Rutas protegidas con autenticación
    Route::middleware(['auth:web'])->group(function () {
        
        // Gestión de instancias
        Route::post('/create', [EvolutionApiController::class, 'createInstance'])
            ->name('evolution.create');
        
        Route::get('/instances', [EvolutionApiController::class, 'listInstances'])
            ->name('evolution.list');
        
        // Envío de mensajes
        Route::post('/send-message/{instanceName?}', [EvolutionApiController::class, 'sendMessage'])
            ->name('evolution.send');
        
        // Integración con Chatwoot
        Route::post('/chatwoot/{instanceName?}', [EvolutionApiController::class, 'setChatwoot'])
            ->name('evolution.chatwoot');
    });
});

