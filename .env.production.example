# === RAILWAY PRODUCTION ENVIRONMENT ===
# Copia estas variables en tu proyecto de Railway (Settings > Variables)

# === APLICACIÓN ===
APP_NAME="MIA App"
APP_ENV=production
APP_KEY=base64:GENERATE_IN_RAILWAY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://app.withmia.com

# === BASE DE DATOS ===
# Railway proporciona automáticamente DATABASE_URL si agregas una base de datos
# Opción 1: Usar DATABASE_URL (Railway lo configura automáticamente)
DB_CONNECTION=mysql
# La variable DATABASE_URL será inyectada por Railway automáticamente

# Opción 2: O configurar manualmente
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=3306
# DB_DATABASE=railway
# DB_USERNAME=root
# DB_PASSWORD=tu_password_generado_por_railway

# === CACHE & SESSION ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# === REDIS (opcional - requiere servicio Redis en Railway) ===
# REDIS_HOST=containers-us-west-xxx.railway.app
# REDIS_PASSWORD=tu_password
# REDIS_PORT=6379
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis

# === BROADCASTING (Reverb/Pusher) ===
BROADCAST_CONNECTION=reverb
# Si usas Pusher en lugar de Reverb:
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1

# Reverb (para WebSockets)
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=https

# === MAIL ===
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tu_email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# === OPENAI (para tu integración de IA) ===
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# === ALMACENAMIENTO ===
FILESYSTEM_DISK=local
# Si quieres usar S3/Spaces:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com (si usas DigitalOcean Spaces)

# === LOGGING ===
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_STACK=single

# === OTROS ===
VITE_APP_NAME="${APP_NAME}"
