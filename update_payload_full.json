                      "name":  "Generate Embeddings"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const item = $input.first();\nconst embedding = item.json.data[0].embedding;\nconst prevData = $(\u0027Split into Chunks\u0027).item.json;\n\n// ID ENTERO basado en timestamp + chunk_index\nconst timestamp = Date.now();\nconst chunkSuffix = prevData.chunk_index.toString().padStart(4, \u00270\u0027);\nconst pointId = parseInt(timestamp.toString() + chunkSuffix);\n\nreturn {\n  json: {\n    id: pointId,\n    vector: embedding,\n    payload: {\n      text: prevData.text,\n      filename: prevData.filename,\n      category: prevData.category,\n      company_slug: prevData.company_slug,\n      chunk_index: prevData.chunk_index,\n      total_chunks: prevData.total_chunks,\n      type: \u0027document\u0027,\n      updated_at: new Date().toISOString()\n    },\n    collection_name: prevData.collection_name,\n    qdrant_host: prevData.qdrant_host,\n    qdrant_api_key: prevData.qdrant_api_key\n  }\n};"
                                     },
