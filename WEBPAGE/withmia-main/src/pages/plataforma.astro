---
import Layout from '@/layouts/Layout.astro';
import { PlatformHero } from '@/components/PlatformHero';
import { AIShowcase } from '@/components/AIShowcase';
import { ComparisonTable } from '@/components/ComparisonTable';

const jsonLd = [
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WITHMIA",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    description: "Plataforma de IA conversacional omnicanal. Inbox unificado con chatbots inteligentes, automatización de ventas y análisis en tiempo real.",
    url: "https://withmia.com/plataforma",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      description: "Plan gratuito disponible",
    },
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "4.8",
      ratingCount: "120",
    },
  }),
];
---

<Layout
  title="Plataforma"
  description="Descubre WITHMIA: inbox omnicanal con IA, automatización de ventas, chatbots inteligentes y análisis en tiempo real para tu negocio."
  path="/plataforma"
  jsonLd={jsonLd}
>
  <PlatformHero client:load />
  <AIShowcase client:visible />
  <ComparisonTable client:visible />
</Layout>
