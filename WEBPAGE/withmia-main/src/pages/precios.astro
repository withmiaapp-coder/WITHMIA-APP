---
import Layout from '@/layouts/Layout.astro';
import { Pricing as MainPricing } from '@/components/Pricing';

const jsonLd = [
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: "WITHMIA",
    description: "Plataforma de IA conversacional omnicanal con inbox unificado, chatbots inteligentes y automatización.",
    url: "https://withmia.com/precios",
    brand: { "@type": "Brand", name: "WITHMIA" },
    offers: [
      {
        "@type": "Offer",
        name: "Plan Gratuito",
        price: "0",
        priceCurrency: "CLP",
        url: "https://withmia.com/precios",
        availability: "https://schema.org/InStock",
      },
      {
        "@type": "Offer",
        name: "WITHMIA Pro Mensual",
        price: "19990",
        priceCurrency: "CLP",
        url: "https://withmia.com/precios",
        availability: "https://schema.org/InStock",
      },
      {
        "@type": "Offer",
        name: "WITHMIA Pro Anual",
        price: "189990",
        priceCurrency: "CLP",
        url: "https://withmia.com/precios",
        availability: "https://schema.org/InStock",
      },
    ],
  }),
];
---

<Layout
  title="Precios"
  description="Precios de WITHMIA. Plan Gratuito para empezar y WITHMIA Pro desde $19.990/mes (IVA incluido). IA conversacional, inbox omnicanal y automatización para tu equipo."
  path="/precios"
  jsonLd={jsonLd}
>
  <MainPricing client:load />
</Layout>
