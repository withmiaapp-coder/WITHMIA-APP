---
import Layout from '@/layouts/Layout.astro';
import FaqPage from '@/views/FaqPage';

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    { "@type": "Question", name: "¿Qué es WITHMIA?", acceptedAnswer: { "@type": "Answer", text: "WITHMIA es una plataforma omnicanal de atención al cliente potenciada con inteligencia artificial. Centraliza conversaciones de WhatsApp, Instagram, correo y más en un solo lugar, con automatización inteligente y analíticas en tiempo real." } },
    { "@type": "Question", name: "¿Necesito conocimientos técnicos para usar WITHMIA?", acceptedAnswer: { "@type": "Answer", text: "No. WITHMIA fue diseñada para que cualquier equipo pueda configurarla sin programar. El asistente de IA, las automatizaciones y los canales se configuran desde una interfaz visual e intuitiva." } },
    { "@type": "Question", name: "¿Qué canales de comunicación soporta WITHMIA?", acceptedAnswer: { "@type": "Answer", text: "WhatsApp Business API, Instagram DM, Facebook Messenger, correo electrónico, chat web, y SMS. Estamos trabajando en agregar Telegram y Google Business Messages." } },
    { "@type": "Question", name: "¿La IA puede aprender de mis documentos?", acceptedAnswer: { "@type": "Answer", text: "Sí. Puedes entrenar el asistente con documentos (PDF, Word, web), base de conocimiento y FAQs. Usa RAG (Retrieval-Augmented Generation) para respuestas precisas basadas en tu información." } },
    { "@type": "Question", name: "¿El bot puede transferir a un agente humano?", acceptedAnswer: { "@type": "Answer", text: "Sí. Detecta automáticamente cuando no puede resolver una consulta y transfiere al agente humano. Puedes configurar reglas de escalamiento, horarios y equipos de asignación." } },
    { "@type": "Question", name: "¿Cómo funciona la facturación?", acceptedAnswer: { "@type": "Answer", text: "La facturación es mensual o anual (con 20% de descuento). Puedes cambiar de plan en cualquier momento. Sin contratos de permanencia." } },
    { "@type": "Question", name: "¿Hay prueba gratuita?", acceptedAnswer: { "@type": "Answer", text: "Sí, ofrecemos 14 días de prueba gratuita con acceso completo a todas las funciones del plan Professional. No se requiere tarjeta de crédito para comenzar." } },
    { "@type": "Question", name: "¿Puedo integrar WITHMIA con mi CRM?", acceptedAnswer: { "@type": "Answer", text: "Sí. Integraciones nativas con HubSpot, Salesforce, Pipedrive y más, a través de conectores directos. También puedes usar la API REST o webhooks para integraciones personalizadas." } },
    { "@type": "Question", name: "¿WITHMIA cumple con la ley de protección de datos?", acceptedAnswer: { "@type": "Answer", text: "Sí. Cumplimos con la Ley N° 19.628 (Chile), estamos preparados para GDPR, usamos cifrado TLS 1.3, almacenamiento seguro y políticas de retención configurables." } },
  ],
});
---

<Layout
  title="Preguntas Frecuentes"
  description="Preguntas frecuentes sobre WITHMIA. Todo lo que necesitas saber sobre nuestra plataforma de IA conversacional, precios, integraciones y más."
  path="/faq"
  jsonLd={[faqJsonLd]}
>
  <FaqPage client:load />
</Layout>
