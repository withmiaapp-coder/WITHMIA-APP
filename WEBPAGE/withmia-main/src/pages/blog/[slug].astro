---
import Layout from '@/layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

// Get related posts (same category, excluding current)
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });
}

const categoryColors: Record<string, string> = {
  'IA Conversacional': 'bg-purple-500/15 text-purple-300 border-purple-500/20',
  'WhatsApp Business': 'bg-green-500/15 text-green-300 border-green-500/20',
  'Atención al Cliente': 'bg-blue-500/15 text-blue-300 border-blue-500/20',
  'Automatización': 'bg-amber-500/15 text-amber-300 border-amber-500/20',
  'Marketing Digital': 'bg-pink-500/15 text-pink-300 border-pink-500/20',
  'PyMEs': 'bg-orange-500/15 text-orange-300 border-orange-500/20',
  'Producto': 'bg-cyan-500/15 text-cyan-300 border-cyan-500/20',
  'Casos de Éxito': 'bg-emerald-500/15 text-emerald-300 border-emerald-500/20',
};

// BlogPosting JSON-LD
const blogPostingJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  publisher: {
    "@type": "Organization",
    name: "WITHMIA",
    logo: { "@type": "ImageObject", url: "https://withmia.com/logos/logo-withmia.png" },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://withmia.com/blog/${post.slug}`,
  },
  ...(post.data.image && { image: `https://withmia.com${post.data.image}` }),
  wordCount: post.body?.split(/\s+/).length || 0,
  ...(post.data.readingTime && { timeRequired: `PT${post.data.readingTime}M` }),
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  inLanguage: "es",
});

// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: "https://withmia.com" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://withmia.com/blog" },
    { "@type": "ListItem", position: 3, name: post.data.title, item: `https://withmia.com/blog/${post.slug}` },
  ],
});
---

<Layout
  title={post.data.title}
  description={post.data.description}
  path={`/blog/${post.slug}`}
  image={post.data.image ? `https://withmia.com${post.data.image}` : undefined}
  type="article"
  jsonLd={[blogPostingJsonLd, breadcrumbJsonLd]}
>
  <article class="pb-20" style="padding-top: 11rem;">
    <div class="article-container">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-10">
        <ol class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.3);">
          <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
          <li><span style="margin: 0 2px; color: rgba(255,255,255,0.15);">/</span></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><span style="margin: 0 2px; color: rgba(255,255,255,0.15);">/</span></li>
          <li style="color: rgba(255,255,255,0.5); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:220px;">{post.data.title}</li>
        </ol>
      </nav>

      <!-- Header -->
      <header style="margin-bottom: 3.5rem;">
        <div class="flex flex-wrap items-center gap-3" style="margin-bottom: 1.5rem;">
          <span class:list={[
            'px-3 py-1 rounded-full text-xs font-semibold border',
            categoryColors[post.data.category] || 'bg-white/5 text-white/60 border-white/10',
          ]} style="letter-spacing: 0.05em; text-transform: uppercase; font-size: 11px;">
            {post.data.category}
          </span>
          <time datetime={post.data.date.toISOString()} style="color: rgba(255,255,255,0.3); font-size: 13px;">
            {formatDate(post.data.date)}
          </time>
          {post.data.readingTime && (
            <span style="color: rgba(255,255,255,0.25); font-size: 13px;">· {post.data.readingTime} min de lectura</span>
          )}
        </div>

        <h1 class="article-title">
          {post.data.title}
        </h1>

        <p class="article-description">
          {post.data.description}
        </p>

        <!-- Author -->
        <div class="flex items-center gap-3" style="padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.06);">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white font-bold" style="font-size: 13px; box-shadow: 0 0 0 2px rgba(255,255,255,0.06);">
            {post.data.author.charAt(0)}
          </div>
          <div>
            <p style="color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 500;">{post.data.author}</p>
            <p style="color: rgba(255,255,255,0.25); font-size: 11px;">WITHMIA</p>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="article-prose">
        <Content />
      </div>

      <!-- Tags -->
      {post.data.tags.length > 0 && (
        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.06);">
          <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.75rem;">Etiquetas</p>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map(tag => (
              <span style="padding: 4px 12px; border-radius: 9999px; font-size: 12px; color: rgba(255,255,255,0.35); background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Share -->
      <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.06);">
        <p style="font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1rem;">Compartir</p>
        <div class="flex flex-wrap gap-2.5">
          <!-- X / Twitter -->
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://withmia.com/blog/${post.slug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white/40 text-[13px] hover:bg-white/[0.07] hover:text-white hover:border-white/[0.15] transition-all duration-300"
            aria-label="Compartir en X (Twitter)"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span>Twitter</span>
          </a>
          <!-- LinkedIn -->
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://withmia.com/blog/${post.slug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white/40 text-[13px] hover:bg-[#0077b5]/10 hover:text-[#0077b5] hover:border-[#0077b5]/20 transition-all duration-300"
            aria-label="Compartir en LinkedIn"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </a>
          <!-- WhatsApp -->
          <a
            href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.data.title + ' → ' + `https://withmia.com/blog/${post.slug}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white/40 text-[13px] hover:bg-[#25d366]/10 hover:text-[#25d366] hover:border-[#25d366]/20 transition-all duration-300"
            aria-label="Compartir por WhatsApp"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>WhatsApp</span>
          </a>
          <!-- Copy link -->
          <button
            id="copy-link-btn"
            class="group inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white/40 text-[13px] hover:bg-white/[0.07] hover:text-white hover:border-white/[0.15] transition-all duration-300 cursor-pointer"
            aria-label="Copiar enlace"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.939a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.757 8.257" /></svg>
            <span id="copy-link-text">Copiar enlace</span>
          </button>
        </div>
      </div>

      <!-- ─── Comments section ─── -->
      <div style="margin-top: 3rem; padding-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.06);">
        <div class="flex items-center justify-between" style="margin-bottom: 2rem;">
          <h3 style="font-size: 1.1rem; font-weight: 700; color: rgba(255,255,255,0.8);">Comentarios</h3>
          <span class="text-[12px] text-white/20" id="comment-count"></span>
        </div>

        <!-- Comment form -->
        <div class="rounded-xl border border-white/[0.06] p-5 mb-8" style="background: rgba(255,255,255,0.015);">
          <div class="grid sm:grid-cols-2 gap-3 mb-3">
            <input
              type="text"
              id="comment-name"
              placeholder="Tu nombre"
              class="w-full px-4 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-white/80 text-[13px] placeholder:text-white/20 focus:outline-none focus:border-amber-400/30 focus:ring-1 focus:ring-amber-400/20 transition-all"
            />
            <input
              type="email"
              id="comment-email"
              placeholder="Email (no se publica)"
              class="w-full px-4 py-2.5 rounded-lg bg-white/[0.03] border border-white/[0.06] text-white/80 text-[13px] placeholder:text-white/20 focus:outline-none focus:border-amber-400/30 focus:ring-1 focus:ring-amber-400/20 transition-all"
            />
          </div>
          <textarea
            id="comment-body"
            rows="3"
            placeholder="Escribe tu comentario..."
            class="w-full px-4 py-3 rounded-lg bg-white/[0.03] border border-white/[0.06] text-white/80 text-[13px] placeholder:text-white/20 focus:outline-none focus:border-amber-400/30 focus:ring-1 focus:ring-amber-400/20 transition-all resize-none mb-3"
          ></textarea>
          <div class="flex items-center justify-between">
            <p class="text-[11px] text-white/15">Sé respetuoso. Tu email no será publicado.</p>
            <button
              id="submit-comment"
              class="px-5 py-2 rounded-lg text-[13px] font-semibold text-white transition-all duration-300 hover:-translate-y-px"
              style="background: linear-gradient(135deg, #f59e0b, #ea580c); box-shadow: 0 4px 20px rgba(245,158,11,0.15);"
            >
              Comentar
            </button>
          </div>
        </div>

        <!-- Comments list -->
        <div id="comments-list" class="space-y-5">
          <!-- Comments loaded via JS from localStorage -->
        </div>
        <p id="no-comments" class="text-center text-[13px] text-white/20 py-8 hidden">
          Sé el primero en comentar.
        </p>
      </div>
    </div>
  </article>

  <!-- Copy link + Comments JS -->
  <script define:vars={{ slug: post.slug }}>
    // ── Copy link ──
    document.getElementById('copy-link-btn')?.addEventListener('click', () => {
      const url = `https://withmia.com/blog/${slug}`;
      navigator.clipboard.writeText(url).then(() => {
        const txt = document.getElementById('copy-link-text');
        if (txt) { txt.textContent = '¡Copiado!'; setTimeout(() => txt.textContent = 'Copiar enlace', 2000); }
      });
    });

    // ── Simple localStorage comments ──
    const STORAGE_KEY = `withmia-comments-${slug}`;

    function loadComments() {
      const raw = localStorage.getItem(STORAGE_KEY);
      const comments = raw ? JSON.parse(raw) : [];
      const list = document.getElementById('comments-list');
      const noComments = document.getElementById('no-comments');
      const countEl = document.getElementById('comment-count');

      if (!list) return;
      list.innerHTML = '';

      if (comments.length === 0) {
        noComments?.classList.remove('hidden');
        if (countEl) countEl.textContent = '';
        return;
      }

      noComments?.classList.add('hidden');
      if (countEl) countEl.textContent = `${comments.length} comentario${comments.length !== 1 ? 's' : ''}`;

      comments.forEach((c) => {
        const el = document.createElement('div');
        el.className = 'flex gap-3.5 p-4 rounded-xl border border-white/[0.05]';
        el.style.background = 'rgba(255,255,255,0.015)';
        el.innerHTML = `
          <div class="shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-violet-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold">${c.name.charAt(0).toUpperCase()}</div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1.5">
              <span class="text-[13px] font-semibold text-white/70">${c.name}</span>
              <span class="text-[11px] text-white/15">${new Date(c.date).toLocaleDateString('es-CL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
            <p class="text-[13px] text-white/40 leading-relaxed">${c.body}</p>
          </div>
        `;
        list.appendChild(el);
      });
    }

    document.getElementById('submit-comment')?.addEventListener('click', () => {
      const name = (document.getElementById('comment-name'))?.value?.trim();
      const email = (document.getElementById('comment-email'))?.value?.trim();
      const body = (document.getElementById('comment-body'))?.value?.trim();

      if (!name || !body) return;

      const raw = localStorage.getItem(STORAGE_KEY);
      const comments = raw ? JSON.parse(raw) : [];
      comments.push({ name, email, body, date: new Date().toISOString() });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(comments));

      // Clear form
      document.getElementById('comment-name').value = '';
      document.getElementById('comment-email').value = '';
      document.getElementById('comment-body').value = '';

      loadComments();
    });

    // Init
    loadComments();
  </script>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section style="padding-bottom: 5rem; padding-left: 1.5rem; padding-right: 1.5rem;">
      <div style="max-width: 680px; margin: 0 auto;">
        <p class="text-[11px] font-semibold text-white/25 uppercase tracking-[0.15em] mb-6">Artículos relacionados</p>
        <div class="grid gap-4">
          {relatedPosts.map(related => (
            <a href={`/blog/${related.slug}`} class="group">
              <article class="rounded-xl border border-white/[0.06] p-5 hover:border-white/[0.12] hover:bg-white/[0.02] transition-all duration-300 flex flex-col sm:flex-row sm:items-center gap-4" style="background: rgba(255,255,255,0.015);">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-2">
                    <span class:list={[
                      'px-2 py-0.5 rounded-full text-[10px] font-semibold border',
                      categoryColors[related.data.category] || 'bg-white/5 text-white/60 border-white/10',
                    ]}>
                      {related.data.category}
                    </span>
                    <span class="text-[11px] text-white/20">{formatDate(related.data.date)}</span>
                  </div>
                  <h3 class="text-[15px] font-semibold text-white/75 group-hover:text-white transition-colors duration-300 leading-snug">
                    {related.data.title}
                  </h3>
                </div>
                <span class="text-amber-400/50 text-[12px] font-medium group-hover:text-amber-400 transition-colors shrink-0">
                  Leer →
                </span>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section style="padding-bottom: 6rem; padding-left: 1.5rem; padding-right: 1.5rem;">
    <div style="max-width: 680px; margin: 0 auto;">
      <div class="rounded-2xl border border-white/[0.06] p-8 sm:p-10 text-center" style="background: rgba(255,255,255,0.015);">
        <h2 class="text-[1.25rem] sm:text-[1.5rem] font-bold text-white tracking-[-0.02em] mb-3">¿Quieres implementar esto en tu negocio?</h2>
        <p class="text-[14px] text-white/35 mb-7 leading-relaxed">Empieza gratis con WITHMIA. Sin tarjeta de crédito.</p>
        <a
          href="https://app.withmia.com"
          class="group inline-flex items-center gap-2.5 px-7 py-3 rounded-full font-semibold text-white text-[14px] transition-all duration-300 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, hsl(43,96%,56%), hsl(36,100%,50%)); box-shadow: 0 4px 25px rgba(245,158,11,0.3);"
        >
          Comenzar gratis
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <style>
    /* ── Article container ── */
    .article-container {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ── Title ── */
    .article-title {
      font-size: 1.75rem;
      font-weight: 700;
      color: white;
      letter-spacing: -0.035em;
      line-height: 1.15;
      margin-bottom: 1.25rem;
    }
    @media (min-width: 640px) {
      .article-title { font-size: 2.25rem; }
    }
    @media (min-width: 1024px) {
      .article-title { font-size: 2.6rem; }
    }

    /* ── Description ── */
    .article-description {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.4);
      line-height: 1.75;
      margin-bottom: 2rem;
    }
    @media (min-width: 640px) {
      .article-description { font-size: 17px; }
    }

    /* ── Prose content ── */
    .article-prose {
      font-size: 16px;
      line-height: 1.85;
      color: rgba(255, 255, 255, 0.55);
      letter-spacing: -0.006em;
    }
    @media (min-width: 640px) {
      .article-prose { font-size: 17px; }
    }

    /* Paragraphs */
    .article-prose :global(p) {
      margin-bottom: 1.75rem;
      line-height: 1.85;
    }

    /* H2 */
    .article-prose :global(h2) {
      font-size: 1.4rem;
      font-weight: 700;
      color: white;
      letter-spacing: -0.03em;
      line-height: 1.3;
      margin-top: 3.5rem;
      margin-bottom: 1.25rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    @media (min-width: 640px) {
      .article-prose :global(h2) { font-size: 1.6rem; }
    }

    /* H3 */
    .article-prose :global(h3) {
      font-size: 1.15rem;
      font-weight: 600;
