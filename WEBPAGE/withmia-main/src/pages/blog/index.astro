---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

function formatDate(date: Date): string {
  return date.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });
}

const catStyle: Record<string, { text: string; bg: string; border: string }> = {
  'IA Conversacional':   { text: 'text-violet-400',  bg: 'bg-violet-500/10',  border: 'border-violet-500/15' },
  'WhatsApp Business':   { text: 'text-emerald-400', bg: 'bg-emerald-500/10', border: 'border-emerald-500/15' },
  'Atención al Cliente': { text: 'text-blue-400',    bg: 'bg-blue-500/10',    border: 'border-blue-500/15' },
  'Automatización':      { text: 'text-amber-400',   bg: 'bg-amber-500/10',   border: 'border-amber-500/15' },
  'Marketing Digital':   { text: 'text-pink-400',    bg: 'bg-pink-500/10',    border: 'border-pink-500/15' },
  'PyMEs':               { text: 'text-orange-400',  bg: 'bg-orange-500/10',  border: 'border-orange-500/15' },
  'Producto':            { text: 'text-cyan-400',    bg: 'bg-cyan-500/10',    border: 'border-cyan-500/15' },
  'Casos de Éxito':      { text: 'text-emerald-400', bg: 'bg-emerald-500/10', border: 'border-emerald-500/15' },
};

const blogJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog WITHMIA",
  description: "Novedades, guías y recursos sobre WITHMIA.",
  url: "https://withmia.com/blog",
  publisher: {
    "@type": "Organization",
    name: "WITHMIA",
    logo: { "@type": "ImageObject", url: "https://withmia.com/logos/logo-withmia.png" },
  },
});
---

<Layout
  title="Blog"
  description="Novedades, guías y recursos sobre WITHMIA: automatización, atención al cliente con IA y crecimiento para empresas."
  path="/blog"
  jsonLd={[blogJsonLd]}
>
  <main class="min-h-screen">

    {/* ════════════════════════════════════════
        SECTION HEADER — matches site pattern
        ════════════════════════════════════════ */}
    <section class="pt-32 sm:pt-40 pb-12 sm:pb-16 px-4">
      <div class="max-w-5xl mx-auto text-center">
        <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-violet-500/10 border border-violet-500/15 text-[13px] text-violet-400 font-semibold mb-6 blog-reveal">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          Blog
        </div>
        <h1 class="text-[2rem] sm:text-[2.75rem] md:text-[3.25rem] font-bold tracking-[-0.035em] leading-[1.1] text-white blog-reveal" style="animation-delay:.08s">
          Novedades y recursos
        </h1>
        <p class="mt-4 text-[14.5px] sm:text-[16px] text-white/30 leading-relaxed max-w-lg mx-auto blog-reveal" style="animation-delay:.14s">
          Actualizaciones de producto, historias del equipo y guías para crecer con IA conversacional.
        </p>
      </div>
    </section>


    {/* ════════════════════════════════════════
        FEATURED ARTICLE — wide glass card
        ════════════════════════════════════════ */}
    {featured && (() => {
      const cat = catStyle[featured.data.category] || catStyle['Producto'];
      return (
        <section class="px-4 pb-8 sm:pb-10">
          <a href={`/blog/${featured.slug}`} class="group block max-w-5xl mx-auto blog-reveal" style="animation-delay:.2s">
            <div class="relative rounded-2xl border border-white/[0.08] overflow-hidden transition-all duration-500 hover:border-white/[0.14] hover:shadow-[0_10px_50px_rgba(0,0,0,0.3)]" style="background: rgba(255,255,255,0.03);">
              {/* Accent top bar */}
              <div class="h-[2px] w-full bg-gradient-to-r from-amber-400/60 via-violet-500/40 to-cyan-400/60"></div>

              <div class="p-7 sm:p-10 md:p-12">
                {/* Meta row */}
                <div class="flex flex-wrap items-center gap-3 mb-5">
                  <span class:list={['inline-flex items-center px-3 py-1 rounded-full text-[11px] font-semibold tracking-wide uppercase border', cat.text, cat.bg, cat.border]}>
                    {featured.data.category}
                  </span>
                  <span class="text-[12px] text-white/25">{formatDate(featured.data.date)}</span>
                  {featured.data.readingTime && (
                    <span class="text-[12px] text-white/20">· {featured.data.readingTime} min de lectura</span>
                  )}
                </div>

                {/* Title */}
                <h2 class="text-[1.5rem] sm:text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.03em] leading-[1.15] text-white/90 group-hover:text-white transition-colors duration-300 max-w-3xl">
                  {featured.data.title}
                </h2>

                {/* Description */}
                <p class="mt-4 text-[14px] sm:text-[16px] text-white/30 leading-[1.7] max-w-2xl group-hover:text-white/40 transition-colors duration-300">
                  {featured.data.description}
                </p>

                {/* Bottom row: author + CTA */}
                <div class="flex flex-wrap items-center gap-5 mt-8 pt-6 border-t border-white/[0.06]">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-[12px] font-bold ring-2 ring-white/[0.06]">
                      {featured.data.author.charAt(0)}
                    </div>
                    <div>
                      <span class="text-[13px] font-medium text-white/60">{featured.data.author}</span>
                    </div>
                  </div>

                  <span class="inline-flex items-center gap-2 ml-auto text-[13px] font-semibold text-amber-400/60 group-hover:text-amber-400 transition-colors duration-300">
                    Leer artículo
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </section>
      );
    })()}


    {/* ════════════════════════════════════════
        REST OF ARTICLES — card grid
        ════════════════════════════════════════ */}
    {rest.length > 0 && (
      <section class="px-4 pb-8 sm:pb-10">
        <div class="max-w-5xl mx-auto grid sm:grid-cols-2 gap-5">
          {rest.map((post, i) => {
            const cat = catStyle[post.data.category] || catStyle['Producto'];
            return (
              <a
                href={`/blog/${post.slug}`}
                class="group block rounded-2xl border border-white/[0.08] overflow-hidden transition-all duration-500 hover:border-white/[0.14] hover:shadow-[0_10px_50px_rgba(0,0,0,0.3)] blog-reveal"
                style={`background: rgba(255,255,255,0.02); animation-delay:${0.28 + i * 0.08}s`}
              >
                <div class="p-6 sm:p-7 flex flex-col h-full">
                  {/* Meta */}
                  <div class="flex items-center gap-3 mb-4">
                    <span class:list={['inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold tracking-wide uppercase border', cat.text, cat.bg, cat.border]}>
                      {post.data.category}
                    </span>
                    <span class="text-[11px] text-white/20 ml-auto">{formatDate(post.data.date)}</span>
                  </div>

                  {/* Title */}
                  <h3 class="text-[1.05rem] sm:text-[1.15rem] font-semibold tracking-[-0.015em] leading-[1.35] text-white/80 group-hover:text-white transition-colors duration-300 mb-3">
                    {post.data.title}
                  </h3>

                  {/* Description */}
                  <p class="text-[13px] text-white/25 leading-[1.7] flex-1 group-hover:text-white/35 transition-colors duration-300">
                    {post.data.description}
                  </p>

                  {/* Footer */}
                  <div class="flex items-center gap-3 mt-5 pt-4 border-t border-white/[0.06]">
                    <div class="w-6 h-6 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-[9px] font-bold">
                      {post.data.author.charAt(0)}
                    </div>
                    <span class="text-[11px] text-white/30">{post.data.author}</span>
                    {post.data.readingTime && (
                      <span class="text-[11px] text-white/15 ml-auto">{post.data.readingTime} min</span>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}


    {/* ════════════════════════════════════════
        CTA SECTION
        ════════════════════════════════════════ */}
    <section class="px-4 pt-8 sm:pt-12 pb-24 sm:pb-32">
      <div class="max-w-5xl mx-auto">
        <div class="rounded-2xl border border-white/[0.06] p-8 sm:p-10 text-center blog-reveal" style={`background: rgba(255,255,255,0.015); animation-delay:${0.28 + rest.length * 0.08 + 0.1}s`}>
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-amber-400/50 mb-3">Próximamente</p>
          <h2 class="text-[1.25rem] sm:text-[1.5rem] font-bold tracking-[-0.02em] text-white/80 mb-2">
            Más artículos en camino
          </h2>
          <p class="text-[13.5px] text-white/25 leading-relaxed max-w-md mx-auto mb-7">
            Guías de automatización, historias de clientes y novedades de la plataforma.
          </p>
          <a
            href="https://app.withmia.com"
            class="group inline-flex items-center gap-2.5 px-7 py-3 rounded-full font-semibold text-white text-[14px] transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, hsl(43,96%,56%), hsl(36,100%,50%)); box-shadow: 0 4px 25px rgba(245,158,11,0.3);"
          >
            Probar WITHMIA gratis
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
          <p class="text-[11px] text-white/15 mt-3">Plan gratuito · Sin tarjeta</p>
        </div>
      </div>
    </section>

  </main>

  <style>
    @keyframes blogReveal {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .blog-reveal {
      animation: blogReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  </style>
</Layout>
