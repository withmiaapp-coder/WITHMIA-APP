Options -MultiViews
RewriteEngine On
RewriteBase /

# HTTPS Redirect (MUST be first)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Astro SSG: each page has its own index.html — no SPA fallback needed.
# Custom 404 page
ErrorDocument 404 /404/index.html

# Cache static assets
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|webp|woff2|svg)$">
Header set Cache-Control "max-age=31536000, public, immutable"
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Security headers
Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set Referrer-Policy "strict-origin-when-cross-origin"
Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://accounts.google.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://app.withmia.com https://accounts.google.com; frame-src https://www.googletagmanager.com https://accounts.google.com https://www.youtube.com; upgrade-insecure-requests; base-uri 'self';"